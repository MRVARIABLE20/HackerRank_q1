# ── OpenRouter (embeddings + LLM) ──────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Tavily (optional — web search for Corrective RAG & Agentic RAG) ─────────
# Get your key at https://app.tavily.com — leave blank to disable web search
TAVILY_API_KEY=your-tavily-key-here
SERPER_API_KEY=your-serper-key-here

# ── Auth ─────────────────────────────────────────────────────────────────────
# Change this to a long random string before deploying
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=480

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (default for dev: backend/rag.db)
# For Postgres: DATABASE_URL_OVERRIDE=postgresql+psycopg://user:pass@host:5432/db
DATABASE_URL_OVERRIDE=
